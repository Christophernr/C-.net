<Window x:Class="formularios.añadir"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:formularios"
        mc:Ignorable="d"
        Title="añadir" Height="450" Width="800">
    <Grid>
        <TextBox Name="txt_nombre" HorizontalAlignment="Left" Margin="205,110,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="137"/>
        <TextBox x:Name="txt_numero" HorizontalAlignment="Left" Margin="205,173,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="137"/>
        <TextBox x:Name="txt_correo" HorizontalAlignment="Left" Margin="205,235,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="137"/>


        <Button x:Name="btn_guardar" Content="Guardar" HorizontalAlignment="Left" Margin="440,92,0,0" VerticalAlignment="Top" Height="27" Width="79" Click="btn_guardar_Click"/>
        <Button x:Name="btn_cancelar" Content="Cancelar" HorizontalAlignment="Left" Margin="440,173,0,0" VerticalAlignment="Top" Height="33" Width="79" Click="btn_cancelar_Click"/>


        <Label Content="Nombre" HorizontalAlignment="Left" Margin="107,106,0,0" VerticalAlignment="Top" Width="93"/>
        <Label Content="Numero Telefónico" HorizontalAlignment="Left" Margin="78,169,0,0" VerticalAlignment="Top" Width="112"/>
        <Label Content="Correo" HorizontalAlignment="Left" Margin="107,231,0,0" VerticalAlignment="Top" Width="93"/>



    </Grid>
</Window>
