<Window x:Class="formularios.modificar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:formularios"
        mc:Ignorable="d"
        Title="modificar" Height="450" Width="800">
    <Grid>
        <Label Content="Nombre" HorizontalAlignment="Left" Margin="107,106,0,0" VerticalAlignment="Top" Width="93"/>
        <Label Content="Numero" HorizontalAlignment="Left" Margin="107,169,0,0" VerticalAlignment="Top" Width="93"/>
        <Label Content="Correo" HorizontalAlignment="Left" Margin="107,231,0,0" VerticalAlignment="Top" Width="93"/>
        <Label x:Name="lbl_id_importando_modificar" Content="Label" HorizontalAlignment="Left" Margin="191,56,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txt_nombre_importado_modificar" HorizontalAlignment="Left" Margin="191,110,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txt_numero_importado_modificar" HorizontalAlignment="Left" Margin="191,177,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txt_correo_importado_modificar" HorizontalAlignment="Left" Margin="191,239,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="btn_guardarCambios" Content="Guardar cambios" HorizontalAlignment="Left" Margin="569,56,0,0" VerticalAlignment="Top" Height="44" Width="95" Click="btn_guardarCambios_Click"/>
        <Button x:Name="btn_volver_modificar" Content="Volver" HorizontalAlignment="Left" Margin="576,130,0,0" VerticalAlignment="Top" Height="38" Width="80" Click="btn_volver_modificar_Click"/>

    </Grid>
</Window>
